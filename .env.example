# Environment Variables

# ─── Google Sheets Integration ───────────────────────────────────────────────
# The spreadsheet to write validated applications into.
# Get this from the URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# Google Cloud service account email (from the JSON key file)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Google Cloud service account private key (from the JSON key file)
# IMPORTANT: Replace newlines with \n in the string, or use a secrets manager
GOOGLE_PRIVATE_KEY=

# ─── Application ──────────────────────────────────────────────────────────────
# Base URL of the deployed app (used in emails or redirects — not required in dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Development ─────────────────────────────────────────────────────────────
# Set to "local" to use local JSON persistence instead of Google Sheets
# Useful when Sheets credentials are not yet set up
PERSISTENCE_MODE=local
